# AI Summarization Platform — Backend Environment Variables
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Copy this file to .env and fill in real values:
#   cp .env.example .env
# NEVER commit .env to git!
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# OpenAI API Key — get from https://platform.openai.com/api-keys
OPENAI_API_KEY=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

# Whisper model size: tiny | base | small | medium | large
# tiny = fastest, least accurate (~1GB RAM)
# base = good balance (~1GB RAM)
# small = better accuracy (~2GB RAM)
# medium = high accuracy (~5GB RAM)
# large = best accuracy (~10GB RAM)
WHISPER_MODEL=base

# Server configuration
HOST=0.0.0.0
PORT=8000

# CORS — comma-separated allowed origins
# Development: http://localhost:3000
# Production: https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:3000

# File upload limits (in bytes)
MAX_PDF_SIZE=10485760
MAX_VIDEO_SIZE=104857600

# Temp directory for processing files
TEMP_DIR=./temp

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
